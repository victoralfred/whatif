# Example workflow for the `whatifd-fork` composite action.
#
# Rename to `whatifd-pr-check.yml` (or any `.yml`) and check it in to
# enable. The `.example` suffix prevents this file from being collected
# by GitHub Actions on the whatifd repo itself — it would otherwise try
# to run against PRs that touch this file and require credentials the
# whatifd repo doesn't have.

name: whatifd PR verdict

on:
  pull_request:
    branches: [main]

permissions:
  contents: read
  pull-requests: write   # required for the PR-comment step

jobs:
  whatifd:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # Security note: GitHub recommends pinning third-party actions
      # to a commit SHA rather than a version tag for production
      # workflows (https://docs.github.com/en/actions/security-guides/
      # security-hardening-for-github-actions#using-third-party-actions).
      # The whatifd repo's own CI uses `@v7` tags as a deliberate
      # trade-off (transparent upgrades vs. supply-chain hardening);
      # operators copying this example into a security-hardened
      # production workflow should replace `@v7` with the SHA of a
      # specific release commit (e.g.,
      # `astral-sh/setup-uv@<sha>  # v7.x.y`) before checking in.
      - name: Set up uv
        uses: astral-sh/setup-uv@v7
        with:
          python-version: "3.12"

      - name: Install whatifd + adapter packages
        run: uv pip install whatifd whatifd-langfuse whatifd-inspect-ai

      - name: Run whatifd fork
        uses: ./.github/actions/whatifd-fork
        with:
          config: whatifd.config.yaml
        env:
          LANGFUSE_HOST: ${{ secrets.LANGFUSE_HOST }}
          LANGFUSE_PUBLIC_KEY: ${{ secrets.LANGFUSE_PUBLIC_KEY }}
          LANGFUSE_SECRET_KEY: ${{ secrets.LANGFUSE_SECRET_KEY }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
